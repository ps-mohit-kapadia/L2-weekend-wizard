# Weekend Wizard local development configuration

# Required shared secret for protected /ready and /chat endpoints
WEEKEND_WIZARD_API_KEY=replace-with-a-shared-secret

# FastAPI runtime binding
WEEKEND_WIZARD_API_HOST=127.0.0.1
WEEKEND_WIZARD_API_PORT=8000

# Client/backend base URL
WEEKEND_WIZARD_API_URL=http://127.0.0.1:8000

# Ordered Ollama model preference
WEEKEND_WIZARD_PREFERRED_MODELS=llama3.1:8b

# Planner/reflection request timeout in seconds
WEEKEND_WIZARD_REQUEST_TIMEOUT=600
WEEKEND_WIZARD_HTTP_MAX_RETRIES=2
WEEKEND_WIZARD_HTTP_RETRY_BACKOFF_SECONDS=0.5

# Logging and observability profile
WEEKEND_WIZARD_OBSERVABILITY_MODE=local
WEEKEND_WIZARD_LOG_LEVEL=INFO

# Local Ollama endpoints
OLLAMA_URL=http://127.0.0.1:11434/api/chat
OLLAMA_TAGS_URL=http://127.0.0.1:11434/api/tags
